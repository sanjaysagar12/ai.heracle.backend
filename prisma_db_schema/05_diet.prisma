// Diet — Meal log table
model Meal {
    id        String   @id @default(uuid()) @db.Uuid
    userId    String   @map("user_id") @db.Uuid
    mealType  String   @map("meal_type") // "breakfast" | "lunch" | "dinner" | "snack"
    date      String   @map("date") //  "YYYY-MM-DD"
    time      String   @map("time") //  "HH:MM"
    data      Json     @map("data") // FoodItem[] — see LogMealResponseDto
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("meals")
}

// Diet — Daily suggestions based on user profile
model DietSuggestion {
    id            String   @id @default(uuid()) @db.Uuid
    userId        String   @map("user_id") @db.Uuid
    suggestion    String   @map("suggestion")
    suggestedMeal Json?    @map("suggested_meal") // Array of FoodItem objects
    date          String   @map("date") // "YYYY-MM-DD"
    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, date])
    @@map("diet_suggestions")
}
