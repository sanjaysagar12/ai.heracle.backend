// Exercise — Exercise database
model Exercise {
    id            Int      @id @default(autoincrement())
    name          String
    secondaryInfo String   @map("secondary_info")
    exerciseType  String   @map("exercise_type")
    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    @@map("exercises")
}

// Workout Session - stores target sets for multiple exercises in a single session
model Session {
    id          Int      @id @default(autoincrement())
    userId      String   @map("user_id") @db.Uuid
    name        String
    // JSON containing categories as a list of strings
    category    Json     @default("[]")
    // JSON array of objects: { "exercise id": number, "setN": { "targetRep": number, "targetKg": number, "targetTime": number } }
    sessionData Json     @map("session_data")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    workoutLogs WorkoutLog[]

    @@map("sessions")
}

// Workout Log - stores individual workout performance data of user
model WorkoutLog {
    id        Int      @id @default(autoincrement())
    userId    String   @map("user_id") @db.Uuid
    sessionId Int?     @map("session_id")
    // JSON array of objects: { "exercise id": number, "setN": { "Rep": number, "Kg": number, "Time": number }, "note": string }
    logData   Json     @map("log_data")
    notes     String?
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

    @@map("workout_logs")
}
